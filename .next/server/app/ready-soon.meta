{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/ready-soon/layout,_N_T_/ready-soon/page,_N_T_/ready-soon"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/ready-soon/__PAGE__",
    "/ready-soon",
    "/_index",
    "/_head"
  ]
}