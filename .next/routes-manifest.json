{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/farms/[farmSlug]",
      "regex": "^/farms/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPfarmSlug": "nxtPfarmSlug"
      },
      "namedRegex": "^/farms/(?<nxtPfarmSlug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/orders/[id]",
      "regex": "^/orders/([^/]+?)(?:/)?$",
