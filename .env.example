# Copy this file to .env.local and paste the values from the existing Flutter AppConfig.
# The anon key is safe for the browser when Row Level Security is configured correctly.
# Never add a Supabase service-role key to NEXT_PUBLIC_* variables or browser code.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-or-publishable-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
